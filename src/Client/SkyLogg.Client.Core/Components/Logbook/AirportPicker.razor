@using SkyLogg.Shared.Features.Logbook
@inherits AppComponentBase

<BitDropdown Items="airportItems"
             FitWidth
             ShowSearchBox
             Placeholder="@Localizer[nameof(AppStrings.SelectAirport)]"
             Value="@selectedValue"
             OnChange="WrapHandled((string? v) => OnAirportChanged(v))"
             OnSearch="WrapHandled((string? s) => OnSearchAirports(s))">
    <ItemTemplate Context="item">
        <BitText>@item.Text</BitText>
    </ItemTemplate>
</BitDropdown>
