@attribute [Route(PageUrls.FlightLogDetail + "/{Id:guid}")]
@attribute [Route("{culture?}" + PageUrls.FlightLogDetail + "/{Id:guid}")]
@attribute [Authorize(Policy = AuthPolicies.PRIVILEGED_ACCESS)]
@attribute [Authorize(Policy = AppFeatures.Logbook.ManageFlightLogs)]
@inherits AppPageBase

<AppPageData Title="@Localizer[nameof(AppStrings.FlightDetail)]"
             PageTitle="@Localizer[nameof(AppStrings.FlightDetailPageTitle)]" />

<LogbookWorkspace>
    @if (isLoading)
    {
        <BitRippleLoading />
    }
    else if (flight is not null)
    {
        <div class="logbook-toolbar">
            <BitText Typography="BitTypography.H5">@flight.FlightDate.ToString("d") · @flight.AircraftRegistration</BitText>
            <BitSpacer />
            <BitButton Href="@($"{PageUrls.AddOrEditFlightLog}/{flight.Id}")" IconName="@BitIconName.Edit" Variant="BitVariant.Outline">
                @Localizer[nameof(AppStrings.Edit)]
            </BitButton>
            <BitButton Color="BitColor.Error" IconName="@BitIconName.Delete" Variant="BitVariant.Outline" OnClick="WrapHandled(ConfirmDelete)">
                @Localizer[nameof(AppStrings.Delete)]
            </BitButton>
        </div>

        <div class="logbook-stats">
            <div class="logbook-stat"><BitText Typography="BitTypography.Body2">@Localizer[nameof(AppStrings.BlockTime)]</BitText><BitText>@flight.TotalBlockTimeDisplay</BitText></div>
            <div class="logbook-stat"><BitText Typography="BitTypography.Body2">@Localizer[nameof(AppStrings.FlightTime)]</BitText><BitText>@flight.TotalFlightTimeDisplay</BitText></div>
            <div class="logbook-stat"><BitText Typography="BitTypography.Body2">@Localizer[nameof(AppStrings.Pic)]</BitText><BitText>@flight.TotalPicTimeDisplay</BitText></div>
            <div class="logbook-stat"><BitText Typography="BitTypography.Body2">@Localizer[nameof(AppStrings.Landings)]</BitText><BitText>@flight.TotalLandings</BitText></div>
        </div>

        @if (string.IsNullOrWhiteSpace(flight.Remarks) is false)
        {
            <LogbookSection Title="@Localizer[nameof(AppStrings.Remarks)]">
                <BitText>@flight.Remarks</BitText>
            </LogbookSection>
        }

        <LogbookSection Title="@Localizer[nameof(AppStrings.Sectors)]">
            <div class="data-table-wrap">
                <table class="data-table">
                    <thead>
                        <tr>
                            <th>#</th>
                            <th>@Localizer[nameof(AppStrings.Route)]</th>
                            <th>@Localizer[nameof(AppStrings.BlockTime)]</th>
                            <th>@Localizer[nameof(AppStrings.FlightTime)]</th>
                            <th>PIC / SIC</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var sector in flight.Sectors.OrderBy(s => s.SectorOrder))
                        {
                            <tr>
                                <td>@sector.SectorOrder</td>
                                <td class="primary-cell">@sector.DepartureAirportDisplay → @sector.ArrivalAirportDisplay</td>
                                <td>@sector.BlockTimeDisplay</td>
                                <td>@sector.FlightTimeDisplay</td>
                                <td class="secondary-cell">@sector.PicTimeDisplay / @sector.SicTimeDisplay</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </LogbookSection>

        <LogbookSection Title="@Localizer[nameof(AppStrings.Crew)]">
            <div class="data-table-wrap">
                <table class="data-table">
                    <thead>
                        <tr>
                            <th>@Localizer[nameof(AppStrings.Name)]</th>
                            <th>@Localizer[nameof(AppStrings.CrewRole)]</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var crew in flight.Crew)
                        {
                            <tr>
                                <td class="primary-cell">@crew.CrewMemberName</td>
                                <td>@crew.RoleType</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </LogbookSection>

        <BitDialog @bind-IsOpen="isDeleteDialogOpen"
                   Title="@Localizer[nameof(AppStrings.DeleteFlight)]"
                   OnOk="WrapHandled(DeleteFlight)">
            <BitText>@Localizer[nameof(AppStrings.AreYouSureDeleteFlight)]</BitText>
        </BitDialog>
    }
</LogbookWorkspace>
