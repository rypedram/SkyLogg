@attribute [Route(PageUrls.FlightReports)]
@attribute [Route("{culture?}" + PageUrls.FlightReports)]
@attribute [Authorize(Policy = AuthPolicies.PRIVILEGED_ACCESS)]
@attribute [Authorize(Policy = AppFeatures.Logbook.ManageFlightLogs)]
@inherits AppPageBase

<AppPageData Title="@Localizer[nameof(AppStrings.Reports)]"
             PageTitle="@Localizer[nameof(AppStrings.ReportsPageTitle)]" />

<LogbookWorkspace>
    @if (isLoading)
    {
        <BitRippleLoading />
    }
    else if (statistics is not null)
    {
        <div class="logbook-stats">
            <div class="logbook-stat"><BitText Typography="BitTypography.Body2">@Localizer[nameof(AppStrings.TotalFlightHours)]</BitText><FlightTimeDisplay Minutes="statistics.TotalFlightMinutes" /></div>
            <div class="logbook-stat"><BitText Typography="BitTypography.Body2">@Localizer[nameof(AppStrings.Night)]</BitText><FlightTimeDisplay Minutes="statistics.TotalNightMinutes" /></div>
            <div class="logbook-stat"><BitText Typography="BitTypography.Body2">@Localizer[nameof(AppStrings.Ifr)]</BitText><FlightTimeDisplay Minutes="statistics.TotalIfrMinutes" /></div>
            <div class="logbook-stat"><BitText Typography="BitTypography.Body2">@Localizer[nameof(AppStrings.TotalFlights)]</BitText><BitText>@statistics.FlightCount</BitText></div>
        </div>

        <div class="logbook-split">
            <LogbookSection Title="@Localizer[nameof(AppStrings.LongestFlight)]">
                <BitText>@FormatFlightStatistic(statistics.LongestFlight)</BitText>
            </LogbookSection>
            <LogbookSection Title="@Localizer[nameof(AppStrings.ShortestFlight)]">
                <BitText>@FormatFlightStatistic(statistics.ShortestFlight)</BitText>
            </LogbookSection>
        </div>

        <LogbookSection Title="@Localizer[nameof(AppStrings.FlightSummary)]">
            <BitStack Gap="0.5rem">
                <BitText>@Localizer[nameof(AppStrings.MostUsedAircraft)]: <strong>@statistics.MostUsedAircraft</strong></BitText>
                <BitText>@Localizer[nameof(AppStrings.MostVisitedAirport)]: <strong>@statistics.MostVisitedAirport</strong></BitText>
            </BitStack>
        </LogbookSection>

        <LogbookSection Title="@Localizer[nameof(AppStrings.MonthlyTrends)]">
            <div class="data-table-wrap">
                <table class="data-table">
                    <thead>
                        <tr>
                            <th>@Localizer[nameof(AppStrings.Month)]</th>
                            <th>@Localizer[nameof(AppStrings.FlightTime)]</th>
                            <th>@Localizer[nameof(AppStrings.FlightCount)]</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var trend in statistics.MonthlyTrends.TakeLast(12))
                        {
                            <tr>
                                <td class="primary-cell">@trend.Year/@trend.Month.ToString("00")</td>
                                <td><FlightTimeDisplay Minutes="trend.FlightMinutes" /></td>
                                <td>@trend.FlightCount</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </LogbookSection>

        <LogbookSection Title="@Localizer[nameof(AppStrings.Achievements)]">
            <div class="data-table-wrap">
                <table class="data-table">
                    <thead>
                        <tr>
                            <th>@Localizer[nameof(AppStrings.Name)]</th>
                            <th>@Localizer[nameof(AppStrings.Description)]</th>
                            <th>@Localizer[nameof(AppStrings.Status)]</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var achievement in achievements)
                        {
                            <tr>
                                <td class="primary-cell">@achievement.Name</td>
                                <td class="secondary-cell">@achievement.Description</td>
                                <td>@achievement.CurrentValue / @achievement.Threshold @(achievement.IsUnlocked ? "✓" : "")</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </LogbookSection>
    }
</LogbookWorkspace>
