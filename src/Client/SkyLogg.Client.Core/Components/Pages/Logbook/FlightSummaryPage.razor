@attribute [Route(PageUrls.FlightSummary)]
@attribute [Route("{culture?}" + PageUrls.FlightSummary)]
@attribute [Authorize(Policy = AuthPolicies.PRIVILEGED_ACCESS)]
@attribute [Authorize(Policy = AppFeatures.Logbook.ManageFlightLogs)]
@inherits AppPageBase

<AppPageData Title="@Localizer[nameof(AppStrings.FlightSummary)]"
             PageTitle="@Localizer[nameof(AppStrings.FlightSummaryPageTitle)]" />

<LogbookWorkspace>
    <div class="logbook-toolbar">
        <BitDatePicker @bind-Value="fromDate" Label="@Localizer[nameof(AppStrings.FromDate)]" />
        <BitDatePicker @bind-Value="toDate" Label="@Localizer[nameof(AppStrings.ToDate)]" />
        <BitButton OnClick="WrapHandled(LoadSummary)" IconName="@BitIconName.Refresh">@Localizer[nameof(AppStrings.Apply)]</BitButton>
        <BitSpacer />
        <BitButton OnClick="WrapHandled(ExportCsv)" IconName="@BitIconName.ExcelDocument" Variant="BitVariant.Outline">CSV</BitButton>
        <BitButton OnClick="WrapHandled(ExportPdf)" IconName="@BitIconName.PDF" Variant="BitVariant.Outline">PDF</BitButton>
    </div>

    @if (isLoading)
    {
        <BitRippleLoading />
    }
    else if (string.IsNullOrWhiteSpace(loadError) is false)
    {
        <BitMessage Color="BitColor.Error">@loadError</BitMessage>
    }
    else if (summary is null)
    {
        <BitMessage Color="BitColor.Error">@Localizer[nameof(AppStrings.FlightSummaryLoadFailed)]</BitMessage>
    }
    else if (summary.FlightCount == 0)
    {
        <BitMessage Color="BitColor.Info">@Localizer[nameof(AppStrings.NoFlightsInRange)]</BitMessage>
    }
    else
    {
        <div class="logbook-stats">
            <div class="logbook-stat"><BitText Typography="BitTypography.Body2">@Localizer[nameof(AppStrings.TotalBlockHours)]</BitText><FlightTimeDisplay Minutes="summary.TotalBlockMinutes" /></div>
            <div class="logbook-stat"><BitText Typography="BitTypography.Body2">@Localizer[nameof(AppStrings.TotalFlightHours)]</BitText><FlightTimeDisplay Minutes="summary.TotalFlightMinutes" /></div>
            <div class="logbook-stat"><BitText Typography="BitTypography.Body2">@Localizer[nameof(AppStrings.Night)]</BitText><FlightTimeDisplay Minutes="summary.TotalNightMinutes" /></div>
            <div class="logbook-stat"><BitText Typography="BitTypography.Body2">@Localizer[nameof(AppStrings.Ifr)]</BitText><FlightTimeDisplay Minutes="summary.TotalIfrMinutes" /></div>
            <div class="logbook-stat"><BitText Typography="BitTypography.Body2">@Localizer[nameof(AppStrings.FlightCount)]</BitText><BitText>@summary.FlightCount</BitText></div>
        </div>

        <div class="logbook-split">
            <LogbookSection Title="@Localizer[nameof(AppStrings.AircraftUsage)]">
                <div class="data-table-wrap">
                    <table class="data-table">
                        <thead>
                            <tr>
                                <th>@Localizer[nameof(AppStrings.Aircraft)]</th>
                                <th>@Localizer[nameof(AppStrings.BlockTime)]</th>
                                <th>@Localizer[nameof(AppStrings.FlightCount)]</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in summary.AircraftUsage)
                            {
                                <tr>
                                    <td class="primary-cell">@item.Registration</td>
                                    <td><FlightTimeDisplay Minutes="item.BlockMinutes" /></td>
                                    <td>@item.FlightCount</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </LogbookSection>

            <LogbookSection Title="@Localizer[nameof(AppStrings.TopAirports)]">
                <div class="data-table-wrap">
                    <table class="data-table">
                        <thead>
                            <tr>
                                <th>ICAO</th>
                                <th>@Localizer[nameof(AppStrings.Name)]</th>
                                <th>@Localizer[nameof(AppStrings.FlightCount)]</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var airport in summary.TopAirports)
                            {
                                <tr>
                                    <td class="primary-cell">@airport.ICAO</td>
                                    <td>@airport.Name</td>
                                    <td>@airport.VisitCount</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </LogbookSection>
        </div>
    }
</LogbookWorkspace>
