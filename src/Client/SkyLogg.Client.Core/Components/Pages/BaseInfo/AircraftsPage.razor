@attribute [Route(PageUrls.BaseInfoAircraft)]
@attribute [Route("{culture?}" + PageUrls.BaseInfoAircraft)]
@attribute [Authorize(Policy = AuthPolicies.PRIVILEGED_ACCESS)]
@attribute [Authorize(Policy = AppFeatures.BaseInfo.ManageAircraft)]
@inherits BaseInfoPageBase

<AppPageData Title="@Localizer[nameof(AppStrings.Aircrafts)]"
             PageTitle="@Localizer[nameof(AppStrings.AircraftsPageTitle)]" />

<BaseInfoWorkspace>
    <BaseInfoToolbar ShowSearch="false"
                     AddButtonText="@Localizer[nameof(AppStrings.AddAircraft)]"
                     OnAdd="WrapHandled(() => OpenAddForm(ResetFormInternal))" />

    @if (isLoading)
    {
        <BitRippleLoading />
    }
    else if (aircraft.Count == 0)
    {
        <BitMessage Color="BitColor.Info">@Localizer[nameof(AppStrings.NoAircraft)]</BitMessage>
    }
    else
    {
        <div class="data-table-wrap">
            <table class="data-table">
                <thead>
                    <tr>
                        <th>@Localizer[nameof(AppStrings.Registration)]</th>
                        <th>@Localizer[nameof(AppStrings.AircraftType)]</th>
                        <th>@Localizer[nameof(AppStrings.Status)]</th>
                        <th class="actions">@Localizer[nameof(AppStrings.Actions)]</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in aircraft)
                    {
                        <tr>
                            <td class="primary-cell">@item.Registration</td>
                            <td>@(item.AircraftTypeDisplay ?? $"{item.Type} {item.Model}")</td>
                            <td>@(!item.IsArchived ? Localizer[nameof(AppStrings.Active)] : Localizer[nameof(AppStrings.Canceled)])</td>
                            <td class="actions">
                                <BaseInfoRowActions OnEdit="WrapHandled(() => OpenEditForm(() => LoadAircraft(item)))"
                                                    OnDelete="WrapHandled(() => ConfirmDeleteAircraft(item))" />
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }

    <BaseInfoFormModal @bind-IsOpen="isFormOpen"
                       Title="@(editingAircraft.Id == Guid.Empty ? Localizer[nameof(AppStrings.AddAircraft)] : Localizer[nameof(AppStrings.UpdateAircraft)])"
                       OnCloseRequested="WrapHandled(() => RequestCloseForm(HasUnsavedChanges(), ResetFormInternal))">
        <EditForm Model="editingAircraft" FormName="BaseInfoAircraftForm" OnValidSubmit="WrapHandled(SaveAircraft)">
            <DataAnnotationsValidator />
            <div class="form-grid-wide">
                <BitTextField @bind-Value="editingAircraft.Registration"
                              Name="AircraftRegistration"
                              Label="@Localizer[nameof(AppStrings.Registration)]" />
                <BitDropdown Items="aircraftTypeItems"
                             NoValidate
                             Name="AircraftTypeId"
                             Label="@Localizer[nameof(AppStrings.AircraftType)]"
                             Placeholder="@Localizer[nameof(AppStrings.SelectAircraftType)]"
                             Value="@selectedAircraftTypeValue"
                             OnChange="WrapHandled((string? v) => OnAircraftTypeChanged(v))" />
                <BitTextField @bind-Value="editingAircraft.Type"
                              Name="AircraftCategory"
                              Label="@Localizer[nameof(AppStrings.AircraftCategory)]" />
                <BitTextField @bind-Value="editingAircraft.Model"
                              Name="AircraftModel"
                              Label="@Localizer[nameof(AppStrings.AircraftModel)]" />
                <BitCheckbox @bind-Value="IsFormActive"
                             Name="AircraftIsActive"
                             Label="@Localizer[nameof(AppStrings.Active)]" />
            </div>
            <div class="form-actions">
                <BitButton ButtonType="BitButtonType.Submit" Color="BitColor.Primary" IsLoading="isSaving">
                    @(editingAircraft.Id == Guid.Empty ? Localizer[nameof(AppStrings.Add)] : Localizer[nameof(AppStrings.Update)])
                </BitButton>
                <BitButton ButtonType="BitButtonType.Button" Variant="BitVariant.Outline" OnClick="WrapHandled(() => RequestCloseForm(HasUnsavedChanges(), ResetFormInternal))">
                    @Localizer[nameof(AppStrings.Cancel)]
                </BitButton>
            </div>
        </EditForm>
    </BaseInfoFormModal>
</BaseInfoWorkspace>

<BaseInfoConfirmDialogs @bind-IsDeleteDialogOpen="isDeleteDialogOpen"
                        DeleteMessage="@Localizer.GetString(nameof(AppStrings.AreYouSureWannaDelete), deleteTargetName ?? string.Empty)"
                        DeleteConfirmed="WrapHandled(DeleteAircraftConfirmed)"
                        DeleteCanceled="WrapHandled(HandleDeleteCanceled)"
                        @bind-IsDiscardDialogOpen="isDiscardDialogOpen"
                        DiscardConfirmed="WrapHandled(HandleDiscardConfirmed)" />
