@attribute [Route(PageUrls.BaseInfoAirports)]
@attribute [Route("{culture?}" + PageUrls.BaseInfoAirports)]
@attribute [Authorize(Policy = AuthPolicies.PRIVILEGED_ACCESS)]
@attribute [Authorize(Policy = AppFeatures.BaseInfo.ManageAirports)]
@inherits BaseInfoPageBase

<AppPageData Title="@Localizer[nameof(AppStrings.Airports)]"
             PageTitle="@Localizer[nameof(AppStrings.AirportsPageTitle)]" />

<BaseInfoWorkspace>
    <BaseInfoToolbar @bind-SearchText="searchText"
                     SearchPlaceholder="@Localizer[nameof(AppStrings.SearchAirportsPlaceholder)]"
                     OnSearch="WrapHandled(SearchAirports)"
                     AddButtonText="@Localizer[nameof(AppStrings.AddAirport)]"
                     OnAdd="WrapHandled(() => OpenAddForm(ResetFormInternal))" />

    @if (isLoading)
    {
        <BitRippleLoading />
    }
    else if (airports.Count == 0)
    {
        <BitMessage Color="BitColor.Info">@Localizer[nameof(AppStrings.NoAirports)]</BitMessage>
    }
    else
    {
        <div class="data-table-wrap">
            <table class="data-table">
                <thead>
                    <tr>
                        <th>@Localizer[nameof(AppStrings.ICAO)]</th>
                        <th>@Localizer[nameof(AppStrings.Name)]</th>
                        <th>@Localizer[nameof(AppStrings.City)]</th>
                        <th>@Localizer[nameof(AppStrings.Country)]</th>
                        <th class="actions">@Localizer[nameof(AppStrings.Actions)]</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var airport in airports)
                    {
                        <tr>
                            <td class="primary-cell">@airport.ICAO@(string.IsNullOrEmpty(airport.IATA) ? "" : $"/{airport.IATA}")</td>
                            <td>@airport.Name</td>
                            <td>@airport.City</td>
                            <td class="secondary-cell">@airport.Country</td>
                            <td class="actions">
                                <BaseInfoRowActions OnEdit="WrapHandled(() => OpenEditForm(() => LoadAirport(airport)))"
                                                    OnDelete="WrapHandled(() => ConfirmDeleteAirport(airport))" />
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }

    <BaseInfoFormModal @bind-IsOpen="isFormOpen"
                       Title="@(editingAirport.Id == Guid.Empty ? Localizer[nameof(AppStrings.AddAirport)] : Localizer[nameof(AppStrings.UpdateAirport)])"
                       OnCloseRequested="WrapHandled(() => RequestCloseForm(HasUnsavedChanges(), ResetFormInternal))">
        <EditForm Model="editingAirport" FormName="BaseInfoAirportForm" OnValidSubmit="WrapHandled(SaveAirport)">
            <DataAnnotationsValidator />
            <div class="form-grid-wide">
                <BitTextField @bind-Value="editingAirport.ICAO" Name="AirportIcao" Label="@Localizer[nameof(AppStrings.ICAO)]" />
                <BitTextField @bind-Value="editingAirport.IATA" Name="AirportIata" Label="@Localizer[nameof(AppStrings.IATA)]" />
                <BitTextField @bind-Value="editingAirport.Name" Name="AirportName" Label="@Localizer[nameof(AppStrings.Name)]" />
                <BitDropdown Items="cityItems"
                             NoValidate
                             Name="AirportCityId"
                             Label="@Localizer[nameof(AppStrings.City)]"
                             Placeholder="@Localizer[nameof(AppStrings.SelectCity)]"
                             Value="@selectedCityValue"
                             OnChange="WrapHandled((string? v) => OnCityChanged(v))" />
                <div class="readonly-field">
                    <BitText Typography="BitTypography.Body2">@Localizer[nameof(AppStrings.Country)]</BitText>
                    <BitText>@(editingAirport.Country ?? "—")</BitText>
                </div>
                <div class="readonly-field">
                    <BitText Typography="BitTypography.Body2">@Localizer[nameof(AppStrings.TimeZone)]</BitText>
                    <BitText>@(editingAirport.TimeZoneDisplay ?? "—")</BitText>
                </div>
                <BitNumberField @bind-Value="editingAirport.Latitude" Name="AirportLatitude" Label="@Localizer[nameof(AppStrings.Latitude)]" />
                <BitNumberField @bind-Value="editingAirport.Longitude" Name="AirportLongitude" Label="@Localizer[nameof(AppStrings.Longitude)]" />
                <BitNumberField @bind-Value="editingAirport.ElevationFt" Name="AirportElevationFt" Label="@Localizer[nameof(AppStrings.ElevationFt)]" />
                <BitCheckbox @bind-Value="IsFormActive" Name="AirportIsActive" Label="@Localizer[nameof(AppStrings.Active)]" />
            </div>
            <div class="form-actions">
                <BitButton ButtonType="BitButtonType.Submit" Color="BitColor.Primary" IsLoading="isSaving">
                    @(editingAirport.Id == Guid.Empty ? Localizer[nameof(AppStrings.Add)] : Localizer[nameof(AppStrings.Update)])
                </BitButton>
                <BitButton ButtonType="BitButtonType.Button" Variant="BitVariant.Outline" OnClick="WrapHandled(() => RequestCloseForm(HasUnsavedChanges(), ResetFormInternal))">
                    @Localizer[nameof(AppStrings.Cancel)]
                </BitButton>
            </div>
        </EditForm>
    </BaseInfoFormModal>
</BaseInfoWorkspace>

<BaseInfoConfirmDialogs @bind-IsDeleteDialogOpen="isDeleteDialogOpen"
                        DeleteMessage="@Localizer.GetString(nameof(AppStrings.AreYouSureWannaDelete), deleteTargetName ?? string.Empty)"
                        DeleteConfirmed="WrapHandled(DeleteAirportConfirmed)"
                        DeleteCanceled="WrapHandled(HandleDeleteCanceled)"
                        @bind-IsDiscardDialogOpen="isDiscardDialogOpen"
                        DiscardConfirmed="WrapHandled(HandleDiscardConfirmed)" />
